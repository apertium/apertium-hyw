PATTERN VerbStemE
VerbRootE(1) VZero VerbRootE(2):
PATTERN VerbStemA
VerbRootA(1) VZero VerbRootA(2):
PATTERN VerbStemI
VerbRootI(1) VZero VerbRootI(2):


#Base of causative is root+th
PATTERN CausBase
VerbStemE ThE 
VerbStemE ThA? # Dir/LR   to capture variation in theme-less or with mismatched vowel 
VerbStemI ThE #  I'm just changing -i- to -e- directly
VerbStemI ThA? # Dir/LR      to capture variation in theme-less or with mismatched vowel 
VerbStemA ThA 
VerbStemA ThE? # Dir/LR   to capture variation in theme-less or with mismatched vowel  

InchBase InchEmpty  #<inch> marked by either covert or overt -n-

#This is for lexically listed causatives
#Lexical causatives take their own special valency tag. Might need to change this later if 
#it violates some tagging rule TO DO
CausativeVerbRoot VZero # [<caus_listed>:]
#Orthographic variants are separately handled based on the inflection lsot


#Irregulars

#Irregulars infixed i-theme
VerbRootNilHyw(1)   VZero VerbRootNilHyw(2):    ThE  #  անցնիլ group from Boyacioglu
VerbRootNilHyw(1)   VZero VerbRootNilHyw(2): (EmptyNasal  ThE)?  #   Dir/LR   to capture variation in theme-less or infix-less

# VerbRootCilV(1)|VerbRootCilC(1)   VZero VerbRootCilV(2):|VerbRootCilC(2):     # կպչիլ group from Boyacioglu
VerbRootCilIlcHyw(1) EmptyAffr VZero VerbRootCilIlcHyw(2):  ThE  		#  դպչիլ դպիլ 
VerbRootCilIlcHyw(1) EmptyAffr? VZero VerbRootCilIlcHyw(2): ThE? #   Dir/LR   to capture variation in theme-less or infix-less
VerbRootCilIliHyw(1) VZero VerbRootCilIliHyw(2):  ThE #   
VerbRootCilIliHyw(1) VZero VerbRootCilIliHyw(2):  #   Dir/LR   to capture variation in theme-less  



#Irregular infixed non-i-theme
VerbRootCelHyw(1)   VZero VerbRootCelHyw(2):    ThE #  թռչել not in Boyacioglu
VerbRootCelHyw(1)   VZero VerbRootCelHyw(2): (EmptyAffr ThE)? #  Dir/LR   to capture variation in theme-less or infix-less

VerbRootNelNale(1)  VZero VerbRootNelNale(2):  ThE  #իջնել իջնալ
VerbRootNelNale(1)  VZero VerbRootNelNale(2): (EmptyNasal ThE)? # Dir/LR   to capture variation in theme-less or infix-less
VerbRootNelNala(1)   VZero VerbRootNelNala(2):   ThA 
VerbRootNelNala(1)  VZero VerbRootNelNala(2): (EmptyNasal ThA)? # Dir/LR   to capture variation in theme-less or infix-less


VerbRootCry(1) VZero VerbRootCry(2): ThA   # լալ
VerbRootBring(1) VZero VerbRootBring(2): ThE   # բերել
VerbRootBring(1) VZero VerbRootBring(2): ThE? # Dir/LR   to capture variation in theme-les
# skip because listed in CausativeVerbRootOrthographicAffr
#VerbRootTurnPres(1) VZero VerbRootBring(2): 
VerbRootSeeA(1)   VZero VerbRootSeeA(2):     # տեսնալ
VerbRootSeeA(1) VZero VerbRootSeeA(2): (EmptyNasal? ThE)? # Dir/LR   to capture variation in theme-less or infix-less
VerbRootSeeE(1)   VZero VerbRootSeeE(2):    # տեսնալ
VerbRootSeeE(1) VZero VerbRootSeeE(2): (EmptyNasal? ThA)? # Dir/LR   to capture variation in theme-less or infix-less
VerbRootPutPres(1) VZero VerbRootPutPres(2): ThE   # դնել
VerbRootHitStop(1) VZero VerbRootHitStop(2): ThE   # զարնել
VerbRootAcceptHyw(1) VZero VerbRootAcceptHyw(2): ThE   #  ընդունիլ
VerbRootFallHywPast(1) VZero VerbRootFallHywPast(2): ThA  #    # իյնալ
VerbRootPlayHyw(1) VZero VerbRootPlayHyw(2):   #   # խաղալ
VerbRootPlayHyw(1) VZero VerbRootPlayHyw(2): ThA     #  Dir/LR խաղալ
VerbRootStayHyw(1) VZero VerbRootStayHyw(2): ThA     #  # մնալ
VerbRootSitHyw(1) VZero VerbRootSitHyw(2): ThE  #  նստիլ
VerbRootEatPast(1) VZero VerbRootEatPast(2):     # ուտել
VerbRootEatPres(1) VZero VerbRootEatPres(2):  ThE   # Dir/LR

#Base of passive is root
PATTERN PassBase
VerbStemE 
VerbStemI  #  
VerbStemA ThA Aor

